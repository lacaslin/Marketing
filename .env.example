# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# CMS Webhook URL (optional, for production push)
CMS_WEBHOOK_URL=https://your-cms.example.com/api/content/push

# CMS API Key
CMS_API_KEY=your-cms-api-key

# Output directory
OUTPUT_DIR=./output

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
